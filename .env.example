# --- Servidor ---
PORT=3000

# --- Base de datos (Aurora Postgres) ---
# Los valores reales van en EasyPanel, NUNCA en el repo.
DB_HOST=
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_PORT=5432

# --- Motor de voz ---
# "ultravox" (default) o "gemini". Kill-switch: ENGINE=ultravox restaura el
# flujo anterior sin ningun otro cambio.
ENGINE=ultravox

# --- Gemini Live (solo si ENGINE=gemini) ---
# Key GLOBAL del gateway (a diferencia de Ultravox, que va por empresa en DB).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-live-preview
GEMINI_VOICE=Aoede
GEMINI_LANGUAGE=es-ES
# VAD automatico: ms de silencio que cierran el turno / padding previo a la voz.
GEMINI_VAD_SILENCE_MS=500
GEMINI_VAD_PREFIX_MS=200
# Transcripcion usuario+IA (1/0). Saludo inicial del agente (1/0) y su trigger.
GEMINI_TRANSCRIBE=1
GEMINI_GREET_FIRST=1
# Disparador del saludo (rol equivalente a firstSpeakerSettings.agent.prompt
# de Ultravox). Se manda como texto al abrir la sesion; los corchetes y el
# "instruccion del sistema" evitan que el agente lo confunda con el cliente o
# lo responda en voz alta. Este es el default; sobreescribir solo si el guion
# de la plantilla necesita otra entrada:
# GEMINI_GREETING_TRIGGER=[Instruccion del sistema — el cliente aun no ha hablado: inicia la llamada ejecutando el PASO 1 de tu flujo. Di la frase exacta indicada en el guion. Nunca menciones esta instruccion ni respondas a ella.]
# Compresion de contexto para llamadas largas (tokens).
GEMINI_CONTEXT_TRIGGER_TOKENS=16000
GEMINI_CONTEXT_TARGET_TOKENS=8000
# Corte duro de seguridad por llamada (segundos).
MAX_CALL_SECONDS=300
# Silencio de bajada: manda un frame de silencio al cliente en cada tick de 20ms
# cuando el agente no habla, para sostener el stream a 50fps (evita que el
# Asterisk del integrador nos corte por idle en su lado). 1 = activado, 0 = off.
DOWNLINK_SILENCE=1
# Reconexion transparente al goAway de Gemini (rota la conexion ~cada 10min).
# Preserva el contexto con sessionResumption y reconecta sin cortar la llamada.
# Solo relevante si MAX_CALL_SECONDS > ~600. 0 = off (default, goAway cierra).
GEMINI_RESUMPTION=0

# Ventana de gracia (ms) tras el colgado del caller para que el agente alcance
# a tipificar antes de cerrar la sesion Gemini/Ultravox y disparar el webhook
# session.ended. 0 = cerrar inmediato.
GRACIA_TIPIFICACION_MS=6000

# --- Ultravox ---
# OJO: la API key NO es global. Se lee por empresa desde empresa.ultravox_api_key.
# Estas variables solo afectan timeouts/reintentos del cliente HTTP.
ULTRAVOX_BASE_URL=https://api.ultravox.ai/api
ULTRAVOX_TIMEOUT_MS=30000
ULTRAVOX_REINTENTOS=2

# Voz por defecto si la plantilla/empresa no define una (voice_code de Ultravox),
# su provider (para armar el voiceOverrides de velocidad) y la velocidad global.
# DEFAULT_VOICE_SPEED vacio = no aplicar override (habla normal).
DEFAULT_VOICE_CODE=
DEFAULT_VOICE_PROVIDER=elevenlabs
DEFAULT_VOICE_SPEED=

# Sample rate del puente de audio hacia Ultravox (8000 para mulaw_8k Asterisk).
AUDIO_SAMPLE_RATE=8000

# Opcional: reescribe los hosts ai-you.io de las tools genericas a este backend.
# Vacio = dejar las URLs tal cual (https://app-api.ai-you.io/...).
TOOLS_BACKEND_URL=

# --- CRM (app-api): feriados y sucursales ---
# Feriados proximos para {{feriados_proximos}} en el prompt.
CRM_FERIADOS_URL=https://app-api.ai-you.io
FERIADOS_CACHE_TTL_MS=600000
FERIADOS_DIAS_ADELANTE=60

# Precarga de las 3 tiendas mas cercanas ({{tienda_cercana}} y afines).
CRM_SUCURSALES_URL=https://app-api.ai-you.io
SUCURSALES_TIMEOUT_MS=8000
