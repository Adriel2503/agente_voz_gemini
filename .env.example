# --- Servidor ---
PORT=3000

# --- Base de datos (Aurora Postgres) ---
# Los valores reales van en EasyPanel, NUNCA en el repo.
DB_HOST=
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_PORT=5432

# --- Ultravox ---
# OJO: la API key NO es global. Se lee por empresa desde empresa.ultravox_api_key.
# Estas variables solo afectan timeouts/reintentos del cliente HTTP.
ULTRAVOX_BASE_URL=https://api.ultravox.ai/api
ULTRAVOX_TIMEOUT_MS=30000
ULTRAVOX_REINTENTOS=2

# Voz por defecto si la plantilla/empresa no define una (voice_code de Ultravox).
DEFAULT_VOICE_CODE=

# Sample rate del puente de audio hacia Ultravox (8000 para mulaw_8k Asterisk).
AUDIO_SAMPLE_RATE=8000

# Opcional: reescribe los hosts ai-you.io de las tools genericas a este backend.
# Vacio = dejar las URLs tal cual (https://app-api.ai-you.io/...).
TOOLS_BACKEND_URL=
